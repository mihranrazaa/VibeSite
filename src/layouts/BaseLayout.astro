---
import "../styles/globals.css";
import Commit from "../components/Commit.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "mihranrazaa",
  description = "Personal portfolio and blog by mihranrazaa",
} = Astro.props;

/**
 * ═══════════════════════════════════════════════════════
 *  MOOD CONFIG — Emjois
 * ═══════════════════════════════════════════════════════
 */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || Astro.url).toString()} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/me.jpeg", Astro.site || Astro.url).toString()} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL("/me.jpeg", Astro.site || Astro.url).toString()} />

    <script is:inline>
      (function() {
        const t = localStorage.getItem("theme");
        if (t !== "light") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Accessibility Skip Link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-background focus:text-foreground">
      Skip to content
    </a>

    <!-- Floating SVG icon canvas -->
    <canvas id="emoji-canvas"></canvas>

    <header class="relative z-10 w-full border-b border-border">
      <div class="mx-auto max-w-2xl flex h-14 items-center justify-between px-5">
        <a href="/" class="text-sm font-semibold tracking-tight text-foreground hover:text-accent transition-colors">
          mihranrazaa
        </a>
        <div class="flex items-center gap-5">
          <nav class="hidden sm:flex items-center gap-5">
            <a href="/" class="text-xs text-muted-foreground hover:text-foreground transition-colors">home</a>
            <a href="/portfolio" class="text-xs text-muted-foreground hover:text-foreground transition-colors">work</a>
            <a href="/blog" class="text-xs text-muted-foreground hover:text-foreground transition-colors">blog</a>
            <a href="/search" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Search">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path>
              </svg>
            </a>
          </nav>
          <!-- Theme toggle -->
          <button id="theme-toggle" class="text-muted-foreground hover:text-foreground transition-colors p-1" aria-label="Toggle theme">
            <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
              <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="sm:hidden text-muted-foreground hover:text-foreground transition-colors p-1" aria-label="Menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="menu-icon">
              <line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="close-icon" class="hidden">
              <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden sm:hidden border-t border-border">
        <nav class="flex flex-col px-5 py-3 gap-2">
          <a href="/" class="text-xs text-muted-foreground hover:text-foreground transition-colors py-1.5">home</a>
          <a href="/portfolio" class="text-xs text-muted-foreground hover:text-foreground transition-colors py-1.5">work</a>
          <a href="/blog" class="text-xs text-muted-foreground hover:text-foreground transition-colors py-1.5">blog</a>
          <a href="/search" class="text-xs text-muted-foreground hover:text-foreground transition-colors py-1.5">search</a>
        </nav>
      </div>
    </header>

    <main id="main-content" class="relative z-10 flex-1 mx-auto w-full max-w-2xl px-5 py-10">
      <slot />
    </main>

    <footer class="relative z-10 border-t border-border mt-10">
      <div class="mx-auto max-w-2xl px-5 py-8 flex flex-col items-center justify-center gap-3 text-xs text-muted-foreground">
        <div class="flex flex-col items-center gap-1 mb-2 hover:text-cyan-400 transition-colors">
          <span class="italic font-medium">"We are Infinite."</span>
          <span class="text-[10px] text-muted-foreground/70">~ Prolly someone</span>
        </div>
        <span>made with ❤️ by mihran</span>
        <div class="flex items-center gap-4">
          <a href="mailto:mihranrazaa@gmail.com" class="hover:text-foreground transition-colors" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          </a>
          <a href="https://github.com/mihranrazaa" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
          </a>
          <a href="https://linkedin.com/in/mihranrazaa" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <a href="https://twitter.com/mihranrazaa" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
          </a>
        </div>
      </div>
      <Commit />
    </footer>

    <script>
      // ===== MOBILE MENU =====
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");
      const menuIcon = document.getElementById("menu-icon");
      const closeIcon = document.getElementById("close-icon");
      btn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
        menuIcon?.classList.toggle("hidden");
        closeIcon?.classList.toggle("hidden");
      });

      // ===== THEME TOGGLE =====
      const toggle = document.getElementById("theme-toggle");
      const sunIconEl = document.getElementById("sun-icon");
      const moonIconEl = document.getElementById("moon-icon");
      function updateIcons() {
        const isDark = document.documentElement.classList.contains("dark");
        sunIconEl?.classList.toggle("hidden", !isDark);
        moonIconEl?.classList.toggle("hidden", isDark);
      }
      updateIcons();
      toggle?.addEventListener("click", () => {
        document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", document.documentElement.classList.contains("dark") ? "dark" : "light");
        updateIcons();
      });

      // ===== FLOATING EMOJI IMAGES =====
      const canvas = document.getElementById("emoji-canvas") as HTMLCanvasElement;
      const ctx = canvas?.getContext("2d");
      
      // EDIT THESE PATHS to change the floating emojis.
      // You can add up to 6 custom image paths here.
      // If a path doesn't exist, it will simply be skipped, keeping everything balanced!
      const emojiPaths = [
        "/emojis/1.svg",
        "/emojis/2.svg",
        "/emojis/3.svg",
        "/emojis/4.svg",
        "/emojis/5.svg",
        "/emojis/6.svg"
      ];

      const loadedImages: HTMLImageElement[] = [];
      let imagesLoaded = 0;

      if (canvas && ctx) {
        emojiPaths.forEach(path => {
          const img = new Image();
          img.src = path;
          img.onload = () => {
            loadedImages.push(img);
            checkInit();
          };
          img.onerror = () => {
            checkInit(); // Skip failed images but don't block
          };
        });

        function checkInit() {
          imagesLoaded++;
          if (imagesLoaded === emojiPaths.length) {
            initCanvas();
          }
        }
        
        function initCanvas() {
          if (loadedImages.length === 0) return; // No valid images found
          if (window.innerWidth < 768 && window.location.pathname !== "/") return;

          let W = window.innerWidth;
          let H = window.innerHeight;
          canvas.width = W;
          canvas.height = H;

          const isMobile = W < 768;
          const COUNT = isMobile
            ? Math.min(15, Math.max(8, Math.floor((W * H) / 30000)))
            : Math.min(55, Math.max(28, Math.floor((W * H) / 14000)));
          const REPEL_RADIUS = isMobile ? 80 : 120;
          const REPEL_FORCE = isMobile ? 1.5 : 2.5;

          interface FloatingIcon {
            x: number; y: number;
            vx: number; vy: number;
            baseVx: number; baseVy: number;
            scale: number;
            rotation: number;
            rotSpeed: number;
            imgIdx: number;
            opacity: number;
          }

          let mouseX = -9999;
          let mouseY = -9999;

          document.addEventListener("mousemove", (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
          });
          document.addEventListener("mouseleave", () => {
            mouseX = -9999;
            mouseY = -9999;
          });

          const items: FloatingIcon[] = [];

          function spawn() {
            items.length = 0;
            for (let i = 0; i < COUNT; i++) {
              const baseVx = (Math.random() - 0.5) * 1.5;
              const baseVy = (Math.random() - 0.5) * 1.5;
              
              // Scale image down specifically for Twemoji SVGs (which are 36x36 natively), or PNGs
              // We want them to look around 24px-36px big, so scale is around 0.5 to 1.2
              const scale = isMobile
                ? Math.random() * 0.4 + 0.3   // 0.3–0.7 on mobile (smaller)
                : Math.random() * 0.7 + 0.5;  // 0.5–1.2 on desktop

              items.push({
                x: Math.random() * W,
                y: Math.random() * H,
                vx: baseVx,
                vy: baseVy,
                baseVx: baseVx,
                baseVy: baseVy,
                scale: scale,
                rotation: Math.random() * Math.PI * 2,
                rotSpeed: (Math.random() - 0.5) * 0.03,
                imgIdx: Math.floor(Math.random() * loadedImages.length),
                opacity: isMobile
                  ? Math.random() * 0.12 + 0.06  // 6%–18% on mobile (much subtler)
                  : Math.random() * 0.25 + 0.15, // 15%–40% on desktop
              });
            }
          }

          function draw() {
            if (!ctx) return;
            ctx.clearRect(0, 0, W, H);

            items.forEach((item) => {
              // Drift
              item.x += item.vx;
              item.y += item.vy;
              item.rotation += item.rotSpeed;

              // Mouse repulsion
              const dx = item.x - mouseX;
              const dy = item.y - mouseY;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < REPEL_RADIUS && dist > 0) {
                const force = ((REPEL_RADIUS - dist) / REPEL_RADIUS) * REPEL_FORCE;
                item.vx += (dx / dist) * force * 0.08;
                item.vy += (dy / dist) * force * 0.08;
              }

              // Content zone repulsion — push out from text column 
              const contentLeft = (W - 672) / 2 - 40;
              const contentRight = (W + 672) / 2 + 40;
              if (item.x > contentLeft && item.x < contentRight) {
                const center = W / 2;
                const pushDir = item.x < center ? -1 : 1;
                item.vx += pushDir * 0.15;
              }

              // Damping — slowly return to natural base speed instead of stopping
              item.vx = item.vx * 0.98 + item.baseVx * 0.02;
              item.vy = item.vy * 0.98 + item.baseVy * 0.02;

              // Wrap seamlessly
              if (item.x < -100) item.x = W + 100;
              if (item.x > W + 100) item.x = -100;
              if (item.y < -100) item.y = H + 100;
              if (item.y > H + 100) item.y = -100;

              // Draw Image
              ctx.save();
              ctx.translate(item.x, item.y);
              ctx.rotate(item.rotation);
              ctx.scale(item.scale, item.scale);
              
              // Give them lower opacity on dark mode to match the theme, slightly brighter on light
              ctx.globalAlpha = document.documentElement.classList.contains("dark") ? item.opacity : Math.min(item.opacity + 0.2, 1);
              
              const img = loadedImages[item.imgIdx];
              // Force draw to 40x40 to keep them uniform, scale handles variance
              const baseSize = 40;
              ctx.drawImage(img, -baseSize / 2, -baseSize / 2, baseSize, baseSize);

              ctx.restore();
            });

            requestAnimationFrame(draw);
          }

          spawn();
          draw();

          window.addEventListener("resize", () => {
            const newW = window.innerWidth;
            const newH = window.innerHeight;

            // On mobile, the browser chrome (address bar, home bar) causes
            // height-only changes. Ignore those to prevent emojis from jumping.
            if (isMobile && newW === W) {
              // Only update canvas height so it doesn't clip, but don't respawn
              H = newH;
              canvas.height = H;
              return;
            }

            W = newW;
            H = newH;
            canvas.width = W;
            canvas.height = H;
            spawn(); // Only respawn on actual layout changes (orientation, desktop resize)
          });
        }
      }
    </script>
  </body>
</html>

