---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Only show h2 and h3 level headings
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="mb-8 border border-border rounded-lg p-4">
    <details open>
      <summary class="text-sm font-semibold tracking-tight cursor-pointer select-none text-foreground hover:text-accent transition-colors">
        Table of Contents
      </summary>
      <ul class="mt-3 space-y-1.5 text-sm">
        {filteredHeadings.map((heading) => (
          <li class={heading.depth === 3 ? "ml-4" : ""}>
            <a
              href={`#${heading.slug}`}
              class="text-muted-foreground hover:text-accent transition-colors leading-relaxed"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </details>
  </nav>
)}
