---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];
  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag} — mihranrazaa`}>
  <section class="py-10">
    <a href="/tags" class="text-xs text-accent hover:underline underline-offset-4 mb-4 inline-block">← all tags</a>
    <h1 class="text-lg font-semibold tracking-tight mb-1">#{tag}</h1>
    <p class="text-xs text-muted-foreground mb-8">{posts.length} post{posts.length !== 1 ? "s" : ""}</p>

    <div class="space-y-5">
      {posts.map((post: any) => (
        <a href={`/blog/${post.id.replace(/\.md$/, "")}`} class="block group">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <span class="text-sm text-foreground group-hover:text-accent transition-colors">
              {post.data.title}
            </span>
            <span class="text-xs text-muted-foreground tabular-nums">
              {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
