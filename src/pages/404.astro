---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 Not Found — mihranrazaa">
  <div class="flex-1 flex flex-col items-center justify-center py-20">
    <div class="flex flex-col items-center text-center">
      <h1 aria-label="404 Not Found" class="text-7xl sm:text-9xl font-bold tracking-tighter text-accent mb-4">
        404
      </h1>
      <span aria-hidden="true" class="text-3xl sm:text-5xl font-medium text-foreground tracking-widest mb-6">
        ¯\_(ツ)_/¯
      </span>
      <p class="text-lg sm:text-xl text-muted-foreground mb-8">
        You are lost BRO...
      </p>
      <a
        href="/"
        class="text-sm font-medium text-foreground hover:text-accent underline underline-offset-4 transition-colors"
      >
        Go back home
      </a>
    </div>
  </div>
</BaseLayout>
