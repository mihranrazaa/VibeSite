---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentPosts = sortedPosts.slice(0, 3);
const allTags = [...new Set(sortedPosts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout title="blog — mihranrazaa">
  <section class="py-10">
    <h1 class="text-lg font-semibold tracking-tight mb-6">blog</h1>

    <!-- Tag filters as simple text links -->
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-x-3 gap-y-1.5 mb-10 text-xs text-muted-foreground">
        <a href="/blog" class="text-foreground font-medium">all tags</a>
        {allTags.map((tag) => (
          <a href={`/tags/${tag}`} class="hover:text-foreground transition-colors">#{tag}</a>
        ))}
      </div>
    )}

    <div class="space-y-5">
      {sortedPosts.map((post) => (
        <a href={`/blog/${post.id.replace(/\.md$/, "")}`} class="block group">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <span class="text-sm text-foreground group-hover:text-accent transition-colors">
              {post.data.title}
            </span>
            <span class="text-xs text-muted-foreground tabular-nums">
              {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            </span>
          </div>
          <p class="text-xs text-muted-foreground mt-1">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

