---
import BaseLayout from "../layouts/BaseLayout.astro";
import WeatherWidget from "../components/WeatherWidget";
import SpotifyWidget from "../components/SpotifyWidget";
---

<BaseLayout title="mihranrazaa">
  <section class="py-10">
    <div class="flex items-center gap-4 mb-4">
      <h1 class="text-2xl font-semibold tracking-tight">
        mihranrazaa
      </h1>
      <div id="profile-pic" class="relative w-16 h-16 rounded-[1.25rem] overflow-hidden group border border-border/50 cursor-pointer">
        <img 
          src="/me.jpeg" 
          alt="mihranrazaa" 
          id="profile-default"
          class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 group-hover:opacity-0"
        />
        <img 
          src="/me-hover.jpeg" 
          alt="mihranrazaa" 
          id="profile-hover"
          class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 group-hover:opacity-100"
        />
      </div>
    </div>

    <script>
      // Mobile touch swap for profile image
      const profilePic = document.getElementById("profile-pic");
      const defaultImg = document.getElementById("profile-default") as HTMLImageElement;
      const hoverImg = document.getElementById("profile-hover") as HTMLImageElement;
      let isSwapped = false;

      profilePic?.addEventListener("click", (e) => {
        e.stopPropagation();
        isSwapped = !isSwapped;
        if (defaultImg && hoverImg) {
          defaultImg.style.opacity = isSwapped ? "0" : "1";
          hoverImg.style.opacity = isSwapped ? "1" : "0";
        }
      });

      document.addEventListener("click", () => {
        if (isSwapped && defaultImg && hoverImg) {
          isSwapped = false;
          defaultImg.style.opacity = "1";
          hoverImg.style.opacity = "0";
        }
      });
    </script>
    <p class="text-sm text-muted-foreground leading-relaxed max-w-lg">
      i build things on the internet and write about it.
    </p>
    <div class="flex gap-4 mt-5 mb-8 text-xs">
      <a href="/blog" class="text-accent hover:underline underline-offset-4">blog →</a>
      <a href="/portfolio" class="text-accent hover:underline underline-offset-4">work →</a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <WeatherWidget client:load />
      <SpotifyWidget discordId="1287023567019704394" client:load />
    </div>
  </section>

  <hr class="border-border" />

  <section class="py-10">
    <h2 class="text-xs font-medium text-muted-foreground uppercase tracking-wider mb-5">about</h2>
    <div class="space-y-4 text-sm text-muted-foreground leading-relaxed max-w-lg">
      <p>
        hey — i'm <strong class="text-foreground">mihranrazaa</strong>. i like building things that live on the internet.
      </p>
      <p>
        i'm into web dev, systems, open source, and anything that involves a terminal and a problem to solve.
      </p>
      <p>
        when i'm not coding, i'm probably exploring some new tool, reading docs, or writing about what i learned.
      </p>
    </div>
  </section>

  <hr class="border-border" />

  <section class="py-10">
    <h2 class="text-xs font-medium text-muted-foreground uppercase tracking-wider mb-5">stack</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <p class="text-xs text-muted-foreground mb-2">languages & frameworks</p>
        <p class="text-sm text-foreground">TypeScript, JavaScript, Python, React, Astro, Node.js</p>
      </div>
      <div>
        <p class="text-xs text-muted-foreground mb-2">tools & platforms</p>
        <p class="text-sm text-foreground">Git, Linux, Docker, Cloudflare, VS Code, Figma</p>
      </div>
    </div>
  </section>

  <hr class="border-border" />

  <section class="py-10">
    <h2 class="text-xs font-medium text-muted-foreground uppercase tracking-wider mb-5">connect</h2>
    <div class="space-y-2 text-sm">
      <a href="mailto:mihranrazaa@gmail.com" class="block text-foreground hover:text-accent transition-colors">
        mihranrazaa@gmail.com
      </a>
      <a href="https://github.com/mihranrazaa" target="_blank" rel="noopener noreferrer" class="block text-foreground hover:text-accent transition-colors">
        github.com/mihranrazaa
      </a>
      <a href="https://linkedin.com/in/mihranrazaa" target="_blank" rel="noopener noreferrer" class="block text-foreground hover:text-accent transition-colors">
        linkedin.com/in/mihranrazaa
      </a>
      <a href="https://twitter.com/mihranrazaa" target="_blank" rel="noopener noreferrer" class="block text-foreground hover:text-accent transition-colors">
        twitter.com/mihranrazaa
      </a>
    </div>
  </section>
</BaseLayout>
